# ============================================================
# HackBase Backend — Environment Variables
# ============================================================
# Copy this file and set actual values before running the app.
# For Git Bash / terminal: export each variable, then run mvn spring-boot:run
# Example:
#   export DB_PASS=yourpassword && export MAIL_USER=abc && export MAIL_PASS=xyz && mvn spring-boot:run
#
# NEVER commit actual values to Git. This file documents what's needed.
# ============================================================

# --- MySQL Database ---
# DB_PORT and DB_NAME have safe defaults (4408 / hackathon_db); no need to export unless different.
DB_PORT=4408
DB_NAME=hackathon_db
DB_USER=root
DB_PASS=your_mysql_password_here      # REQUIRED — no default

# --- Mailtrap SMTP (Email Testing) ---
# Get credentials from: https://mailtrap.io -> Email Testing -> My Inbox -> SMTP Settings
MAIL_USER=your_mailtrap_smtp_username  # REQUIRED — no default
MAIL_PASS=your_mailtrap_smtp_password  # REQUIRED — no default

# --- Redis (for 2FA OTP storage and rate limiting) ---
# Defaults to localhost:6379 — only set if using a non-default Redis instance
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ============================================================
# Quick Start (Git Bash / Linux / macOS):
#   export DB_PASS=jumble@123
#   export MAIL_USER=057b228cb46f08
#   export MAIL_PASS=45aa48d5bf469e
#   mvn spring-boot:run
#
# Quick Start (PowerShell):
#   $env:DB_PASS="jumble@123"; $env:MAIL_USER="057b228cb46f08"; $env:MAIL_PASS="45aa48d5bf469e"; mvn spring-boot:run
# ============================================================
