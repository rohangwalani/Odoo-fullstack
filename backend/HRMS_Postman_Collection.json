{
  "info": {
    "name": "HRMS Auth & Employee API",
    "description": "Postman Collection for HRMS Authentication, Company & Employee Management Module",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. Company Signup",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "companyName", "value": "Global Tech", "type": "text" },
                { "key": "firstName", "value": "John", "type": "text" },
                { "key": "lastName", "value": "Doe", "type": "text" },
                { "key": "email", "value": "john.doe@globaltech.com", "type": "text" },
                { "key": "phone", "value": "9876543210", "type": "text" },
                { "key": "password", "value": "Secure@123", "type": "text" }
              ]
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/company/signup",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "company", "signup"]
            }
          }
        },
        {
          "name": "2. Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@techinnovators.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "3. Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:8080/api/auth/logout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Employee Management (Admin)",
      "item": [
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:8080/api/employees",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "employees"]
            }
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:8080/api/profile",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "profile"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "jwt_token",
      "value": "YOUR_TOKEN_HERE"
    }
  ]
}
