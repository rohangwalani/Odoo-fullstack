{
	"info": {
		"_postman_id": "hackbase-hrms-v1",
		"name": "HackBase HRMS API",
		"description": "HRMS API covering Auth, JWT, and Employee Management.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{"key": "baseUrl", "value": "http://localhost:8080", "type": "string"},
		{"key": "adminToken", "value": "", "type": "string"},
		{"key": "employeeToken", "value": "", "type": "string"},
		{"key": "adminId", "value": "", "type": "string"},
		{"key": "companyId", "value": "", "type": "string"},
		{"key": "employeeId", "value": "", "type": "string"}
	],
	"item": [
		{
			"name": "1. Auth & Onboarding",
			"item": [
				{
					"name": "Register Company",
					"event": [{"listen": "test", "script": {"exec": [
						"pm.test('Status is 201', () => pm.response.to.have.status(201));",
						"pm.collectionVariables.set('adminId', pm.response.json().userId);",
						"pm.collectionVariables.set('companyId', pm.response.json().companyId);"
					], "type": "text/javascript"}}],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{"key": "companyName", "value": "Odoo India", "type": "text"},
								{"key": "firstName", "value": "Admin", "type": "text"},
								{"key": "lastName", "value": "User", "type": "text"},
								{"key": "email", "value": "admin@odoo.com", "type": "text"},
								{"key": "password", "value": "Secret@123", "type": "text"},
								{"key": "phone", "value": "9999999999", "type": "text"}
							]
						},
						"url": {"raw": "{{baseUrl}}/api/auth/company/signup", "host": ["{{baseUrl}}"], "path": ["api", "auth", "company", "signup"]}
					}
				},
				{
					"name": "Login as Admin",
					"event": [{"listen": "test", "script": {"exec": [
						"pm.test('Status is 200', () => pm.response.to.have.status(200));",
						"if(pm.response.json().token) pm.collectionVariables.set('adminToken', pm.response.json().token);"
					], "type": "text/javascript"}}],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n  \"email\": \"admin@odoo.com\",\n  \"password\": \"Secret@123\"\n}"},
						"url": {"raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"]}
					}
				}
			]
		},
		{
			"name": "2. Employee Management",
			"item": [
				{
					"name": "Create Employee (Admin)",
					"event": [{"listen": "test", "script": {"exec": [
						"pm.test('Status is 201', () => pm.response.to.have.status(201));",
						"pm.collectionVariables.set('employeeId', pm.response.json().id);"
					], "type": "text/javascript"}}],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{adminToken}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {"mode": "raw", "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john@odoo.com\",\n  \"department\": \"Engineering\",\n  \"designation\": \"Developer\",\n  \"role\": \"EMPLOYEE\"\n}"},
						"url": {"raw": "{{baseUrl}}/api/employees", "host": ["{{baseUrl}}"], "path": ["api", "employees"]}
					}
				},
				{
					"name": "Get All Employees (Admin)",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}],
						"url": {"raw": "{{baseUrl}}/api/employees", "host": ["{{baseUrl}}"], "path": ["api", "employees"]}
					}
				}
			]
		},
		{
			"name": "3. Employee Profile",
			"item": [
				{
					"name": "Update Profile",
					"request": {
						"method": "PUT",
						"header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}],
						"body": {
							"mode": "formdata",
							"formdata": [
								{"key": "phone", "value": "8888888888", "type": "text"},
								{"key": "address", "value": "123 Tech Park", "type": "text"}
							]
						},
						"url": {"raw": "{{baseUrl}}/api/employees/{{adminId}}/profile", "host": ["{{baseUrl}}"], "path": ["api", "employees", "{{adminId}}", "profile"]}
					}
				}
			]
		}
	]
}
